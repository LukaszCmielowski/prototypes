# Copy this file to .env and fill in your values.
# In the notebook, run: from dotenv import load_dotenv; load_dotenv()
# Or export variables in your shell before starting Jupyter.

# RHOAI inference endpoint (base URL of your deployed model)
RHOAI_INFERENCE_URL=https://your-model-name.apps.rosa.rhoai-dev.example.com

# Bearer token for authentication (from OpenShift AI / inference service)
RHOAI_TOKEN=

# Optional: override API base if different from RHOAI_INFERENCE_URL (e.g. without /v1)
# RHOAI_API_BASE=https://your-model-name.apps.rosa.rhoai-dev.example.com/v1
